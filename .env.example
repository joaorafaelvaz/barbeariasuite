# ─── BarbeariaSuite Platform — Variáveis de Ambiente ─────────────────────────
# Copie este arquivo para .env (dev), .env.staging ou .env.production
# e preencha com os valores reais. NUNCA commitar arquivos .env com secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# MariaDB / MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/barbeariasuite"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# URL base da aplicação (sem barra final)
#   Dev:      http://localhost:3998
#   Staging:  https://suite.franquiabv.xyz
#   Prod:     https://app.seudominio.com.br
NEXTAUTH_URL="http://localhost:3998"

# Secret aleatório — gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ── Google OAuth (opcional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── WahaSend — WAHA (WhatsApp HTTP API) ──────────────────────────────────────
WAHA_API_URL="http://localhost:3001"
WAHA_API_KEY=""

# ── VipCam Python Backend (opcional) ─────────────────────────────────────────
# URL do serviço FastAPI de análise facial — configurável também via UI
# VIPCAM_BACKEND_URL="http://localhost:8000"
